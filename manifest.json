{
  "manifest_version": 3,
  "name": "Pseudo",
  "version": "1.0.1",
  "description": "Convert pseudocode to real code using your own AI key — with token tracking, Resource Units, and session history. Runs directly in your browser, no backend.",

  "permissions": ["storage", "activeTab", "scripting", "clipboardWrite"],

  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://api.deepseek.com/*",
    "https://api.x.ai/*",
    "https://api.moonshot.cn/*",
    "https://openrouter.ai/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/problems/*",
        "https://codeforces.com/problemset/problem/*",
        "https://codeforces.com/contest/*/problem/*",
        "https://www.hackerrank.com/challenges/*",
        "https://atcoder.jp/contests/*/tasks/*",
        "https://www.codechef.com/problems/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Toggle Pseudo"
  },

  "web_accessible_resources": [
    {
      "resources": [
        "panel.html",
        "panel.css",
        "panel/index.js",
        "panel/constants.js",
        "panel/state.js",
        "panel/dom.js",
        "panel/pricing.js",
        "panel/models.js",
        "panel/metrics.js",
        "panel/shortcuts.js",
        "panel/panel-mode.js",
        "panel/api.js",
        "panel/storage.js",
        "panel/session.js",
        "panel/history.js",
        "panel/dropdowns.js",
        "panel/generate.js",
        "panel/events.js"
      ],
      "matches": ["<all_urls>"]
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
